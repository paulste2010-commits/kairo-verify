<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verified</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { min-height:100vh; display:flex; align-items:center; justify-content:center; background:#1a1a2e; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; }
        .card { width:100%; max-width:400px; background:#16213e; border:1px solid rgba(255,255,255,0.06); border-radius:20px; padding:48px 36px; text-align:center; box-shadow:0 24px 80px rgba(0,0,0,0.5); }
        .check { width:64px; height:64px; border-radius:50%; background:rgba(34,197,94,0.1); border:2px solid rgba(34,197,94,0.3); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:28px; }
        h1 { font-size:20px; font-weight:700; color:#22c55e; margin-bottom:8px; }
        p { font-size:13px; color:rgba(255,255,255,0.45); margin-bottom:28px; line-height:1.5; }
        .btn { display:block; width:100%; padding:14px; border:none; border-radius:10px; background:#5865F2; color:#fff; font-size:15px; font-weight:600; cursor:pointer; transition:background 0.2s; }
        .btn:hover { background:#4752C4; }
    </style>
</head>
<body>
    <div class="card">
        <div class="check">✓</div>
        <h1>Verified!</h1>
        <p>You can close this window and return to Discord.</p>
        <button class="btn" onclick="closeTab();">Close</button>
    </div>
    <script>
        window.focus();
        function closeTab() {
            window.open('', '_self');
            window.close();
        }
    </script>
</body>
</html>
