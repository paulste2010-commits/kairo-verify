<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kairo Verify</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; text-align:center; }
        .card { max-width:480px; }
        .logo { width:64px; height:64px; background:linear-gradient(135deg,#8b5cf6,#6366f1); border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:28px; margin:0 auto 24px; }
        h1 { font-size:28px; font-weight:700; margin-bottom:12px; }
        p { font-size:14px; color:rgba(255,255,255,0.6); margin-bottom:32px; line-height:1.6; }
        .btn { display:inline-flex; align-items:center; gap:8px; padding:14px 32px; border-radius:12px; font-weight:600; font-size:15px; text-decoration:none; transition:all 0.2s; }
        .btn-primary { background:#4f46e5; color:#fff; }
        .btn-primary:hover { background:#4338ca; transform:translateY(-1px); }
        .btn-ghost { background:transparent; color:rgba(255,255,255,0.6); border:1px solid rgba(255,255,255,0.08); margin-left:12px; }
        .btn-ghost:hover { border-color:rgba(255,255,255,0.15); color:#fff; }
    </style>
</head>
<body>
    <div class="page">
        <div class="card">
            <div class="logo">⚡</div>
            <h1>Kairo Verify</h1>
            <p>Discord verification system with GDPR-compliant email and IP collection.</p>
            <div>
                <a href="<%= inviteUrl %>" class="btn btn-primary">Add Bot</a>
                <a href="/" class="btn btn-ghost">Dashboard</a>
            </div>
        </div>
    </div>
</body>
</html>
