<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify - <%= guildName %></title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { min-height:100vh; display:flex; align-items:center; justify-content:center; background:#1a1a2e; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; }
        .card { width:100%; max-width:400px; background:#16213e; border:1px solid rgba(255,255,255,0.06); border-radius:20px; padding:48px 36px; text-align:center; box-shadow:0 24px 80px rgba(0,0,0,0.5); }
        .icon { width:80px; height:80px; border-radius:50%; margin:0 auto 20px; overflow:hidden; border:3px solid rgba(255,255,255,0.08); }
        .icon img { width:100%; height:100%; object-fit:cover; }
        .icon-fallback { width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#5865F2,#7289DA); color:#fff; font-size:28px; font-weight:700; }
        h1 { font-size:20px; font-weight:700; color:#fff; margin-bottom:8px; }
        p { font-size:13px; color:rgba(255,255,255,0.45); margin-bottom:28px; line-height:1.5; }
        .btn { display:block; width:100%; padding:14px; border:none; border-radius:10px; background:#5865F2; color:#fff; font-size:15px; font-weight:600; cursor:pointer; transition:background 0.2s, transform 0.1s; }
        .btn:hover { background:#4752C4; }
        .btn:active { transform:scale(0.98); }
        .footer { margin-top:20px; font-size:11px; color:rgba(255,255,255,0.25); }
    </style>
</head>
<body>
    <div class="card">
        <% if (guildIcon) { %>
            <div class="icon"><img src="<%= guildIcon %>" alt="Server Icon"></div>
        <% } else { %>
            <div class="icon"><div class="icon-fallback"><%= guildName.charAt(0).toUpperCase() %></div></div>
        <% } %>
        <h1><%= guildName %></h1>
        <p>Click below to verify and get access to the server.</p>
        <form method="POST" action="/consent/<%= guildId %>/<%= userId %>">
            <button type="submit" class="btn">Verify</button>
        </form>
        <div class="footer">Kairo Verify</div>
    </div>
    <script>window.focus();</script>
</body>
</html>
