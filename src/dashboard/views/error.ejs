<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - Kairo Verify</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .page { min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px; }
        .card { width:100%; max-width:440px; background:rgba(255,255,255,0.02); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.08); border-radius:24px; padding:48px 40px; text-align:center; box-shadow:0 16px 64px rgba(0,0,0,0.4); }
        .icon { width:80px; height:80px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:36px; margin:0 auto 24px; background:linear-gradient(135deg,rgba(239,68,68,0.12),rgba(239,68,68,0.05)); border:1px solid rgba(239,68,68,0.2); }
        h1 { font-size:24px; font-weight:700; margin-bottom:12px; color:#ef4444; }
        p { font-size:14px; color:rgba(255,255,255,0.6); line-height:1.6; margin-bottom:32px; }
        .btn { display:inline-flex; align-items:center; gap:8px; padding:14px 32px; border-radius:12px; font-weight:600; font-size:15px; text-decoration:none; transition:all 0.2s; background:#4f46e5; color:#fff; }
        .btn:hover { background:#4338ca; }
    </style>
</head>
<body>
    <div class="page">
        <div class="card">
            <div class="icon">❌</div>
            <h1><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
            <p><%= typeof message !== 'undefined' ? message : 'An error occurred.' %></p>
            <a href="/" class="btn">Back</a>
        </div>
    </div>
</body>
</html>
